    Component {
      Type          CScript
      Name          "Power Theory"
      Show          on
      Position      [860, 690]
      Direction     up
      Flipped       off
      LabelPosition south
      Parameter {
        Variable      "DialogGeometry"
        Value         "[3347 202 1068 877]"
        Show          off
